2025-08-27 13:49:52.677 [http-nio-8080-exec-5] DEBUG o.s.web.servlet.view.JstlView - View name [admin/gallery/list], model {galleries=[Gallery{uid=8263, name='정재우', title='teerere', content='<p>dfasfdsfdsfdsf</p><figure class="image image-style-align-right"><img style="aspect-ratio:137/145;" src="/uploads/gallery/3c2fc217-16f1-43f5-8ede-d32e3986c8d6.jpg" width="137" height="145"></figure>', img='null', regdate=2025-08-07T06:24:37.407528, createdAt=2025-08-07T06:24:37, updatedAt=2025-08-07T06:24:50, ref=null}, Gallery{uid=381, name='정재우', title='테스트', content='<p>ㅇㄹㅇㄹㅇㄹㅇㄹㅇㄹㄴ</p><p>ㅇㄹㅇㄹㅇㄹㅇㅇㄹㅇㄴㄹ</p><p>ㄴㅇㄹ</p><p>ㄴㅇㄹㅇㄴㄹ</p><p>ㅇㄴㄹㅇㄴㄹㄴ</p><p>&nbsp;</p><p>&nbsp;</p><figure class="image image-style-align-center"><img style="aspect-ratio:137/145;" src="/uploads/gallery/6b7230bc-eedf-4852-8996-f1ddaa7fb120.jpg" width="137" height="145"></figure>', img='06f4e8d9-8f70-464e-b2ba-d1a7ae0bc973.png', regdate=2025-07-02T18:45:22.997254, createdAt=2025-07-02T18:45:23, updatedAt=2025-08-07T06:15:33, ref=8}, Gallery{uid=199, name='한지훈', title='셀틱 셀틱 파크 관전기', content='<p>셀틱 파크에서 셀틱 경기를 관전했습니다. 스코틀랜드 축구의 열정적인 분위기가 정말 인상적이었어요. 경기장의 역사적인 분위기와 관중들의 응원이 정말 대단했습니다. 스코틀랜드 축구의 매력을 직접 느낄 수 있었습니다.</p>', img='ed827075-5d1e-4456-a0a9-368ae8483008.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:14:47, ref=null}, Gallery{uid=198, name='정유진', title='PSV 필립스 스타디움 관전 후기', content='<p>필립스 스타디움에서 PSV 경기를 관전했습니다. 네덜란드 축구의 기술적 완성도가 정말 인상적이었어요. 경기장의 분위기와 관중들의 응원이 정말 열정적이었습니다. 네덜란드 축구의 매력을 직접 느낄 수 있어서 좋았습니다.</p>', img='8637afbc-3e01-4dd6-8a0b-b9dacb846b8c.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:15:01, ref=null}, Gallery{uid=197, name='최민수', title='아약스 요한 크루이프 아레나 관전기', content='<p>요한 크루이프 아레나에서 아약스 경기를 관전했습니다. 네덜란드 축구의 공격적 플레이가 정말 인상적이었어요. 경기장의 현대적인 시설과 관중들의 열정이 정말 대단했습니다. 네덜란드 축구의 매력을 직접 느낄 수 있었습니다.</p>', img='2028e48d-5ef4-419b-9e41-f34b3c3d37ee.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:22:13, ref=2}, Gallery{uid=196, name='박서연', title='벤피카 루스 관전 후기', content='<p>루스에서 벤피카 경기를 관전했습니다. 포르투갈 축구의 전통을 직접 볼 수 있어서 좋았어요. 경기장의 분위기와 관중들의 응원이 정말 열정적이었습니다. 포르투갈 축구의 매력을 직접 느낄 수 있었습니다.</p>', img='5606252d-2efe-4f3b-9347-d18ed9b24e2f.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:22:56, ref=null}, Gallery{uid=195, name='이준호', title='포르투 드라강 관전기', content='<p>드라강에서 포르투 경기를 관전했습니다. 포르투갈 축구의 기술적 완성도가 정말 인상적이었어요. 경기장의 아름다운 건축물과 관중들의 열정이 정말 대단했습니다. 포르투갈 축구의 매력을 직접 느낄 수 있어서 좋았습니다.</p>', img='a4172109-7c62-4600-9593-aacf2cc27ab7.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:23:41, ref=1}, Gallery{uid=194, name='김다은', title='세비야 산체스 피스후안 관전 후기', content='<p>산체스 피스후안에서 세비야 경기를 관전했습니다. 안달루시아의 열정적인 분위기가 정말 인상적이었어요. 경기장의 아름다운 건축물과 관중들의 응원이 정말 대단했습니다. 스페인 축구의 매력을 직접 느낄 수 있었습니다.</p>', img='07e34345-c86a-459e-b1dc-5d449d917c8c.jpg', regdate=2025-07-02T09:00, createdAt=2025-07-03T02:18:03, updatedAt=2025-07-13T20:24:29, ref=null}, Gallery{uid=8261, name='강미영', title='레인저스 아이브록스 관전 후기', content='아이브록스에서 레인저스 경기를 관전했습니다. 스코틀랜드 축구의 전통을 직접 볼 수 있어서 좋았어요. 경기장의 분위기와 관중들의 열정이 정말 인상적이었습니다. 스코틀랜드 축구의 매력을 직접 느낄 수 있었습니다.', img='null', regdate=2024-02-05T01:30, createdAt=2025-07-17T12:44:17, updatedAt=2025-07-17T12:44:17, ref=null}, Gallery{uid=8241, name='강미영', title='레인저스 아이브록스 관전 후기', content='아이브록스에서 레인저스 경기를 관전했습니다. 스코틀랜드 축구의 전통을 직접 볼 수 있어서 좋았어요. 경기장의 분위기와 관중들의 열정이 정말 인상적이었습니다. 스코틀랜드 축구의 매력을 직접 느낄 수 있었습니다.', img='null', regdate=2024-02-05T01:30, createdAt=2025-07-17T12:35:57, updatedAt=2025-07-17T12:35:57, ref=null}], currentPage=0, totalPages=235, totalItems=2348, hasNext=true, hasPrevious=false}
